              "pm.test(\"Search returns only Smartphone\", function () {\r",
              "    const response = pm.response.json();\r",
              "\r",
              "    pm.expect(response.items).to.be.an(\"array\").with.lengthOf(1);\r",
              "    pm.expect(response.items[0].name).to.eql(\"Smartphone\");\r",
              "    pm.expect(response.pagination.page).to.eql(1);\r",
              "    pm.expect(response.pagination.totalItems).to.eql(1);\r",
              "    pm.expect(response.pagination.totalPages).to.eql(1);\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
