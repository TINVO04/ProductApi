    {
      "name": "Create Product",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {\r",
              "    pm.response.to.have.status(201);\r",
              "});\r",
              "\r",
              "pm.test(\"Response is JSON\", function () {\r",
              "    pm.expect(pm.response.headers.get(\"Content-Type\"))\r",
              "        .to.include(\"application/json\");\r",
              "});\r",
              "\r",
              "pm.test(\"Location header points to created product\", function () {\r",
              "    const response = pm.response.json();\r",
              "    const location = pm.response.headers.get(\"Location\");\r",
              "\r",
              "    pm.expect(response.id).to.be.a(\"number\").and.to.be.above(0);\r",
              "    pm.expect(location).to.be.a(\"string\");\r",
              "    pm.expect(location.toLowerCase())\r",
              "        .to.include(`/api/products/${response.id}`);\r",
              "});\r",
              "\r",
              "pm.test(\"Created product matches request body\", function () {\r",
              "    const response = pm.response.json();\r",
              "\r",
              "    pm.expect(response.name).to.eql(\"Keyboard\");\r",
              "    pm.expect(response.price).to.eql(75.5);\r",
              "    pm.expect(response.quantity).to.eql(15);\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"name\": \"Keyboard\",\r\n  \"price\": 75.5,\r\n  \"quantity\": 15\r\n}\r\n",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/products",
          "host": [
            "{{baseUrl}}"
          ],
