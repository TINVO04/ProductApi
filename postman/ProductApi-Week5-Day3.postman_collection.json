              "});",
              "",
              "pm.test(\"Response uses Problem Details JSON\", function () {",
              "    pm.expect(pm.response.headers.get(\"Content-Type\"))",
              "        .to.include(\"application/problem+json\");",
              "});",
              "",
              "pm.test(\"Validation errors include product name rule\", function () {",
              "    const response = pm.response.json();",
              "    const body = JSON.stringify(response);",
              "",
              "    pm.expect(response).to.have.property(\"errors\");",
              "    pm.expect(body).to.match(/name|between 2 and 100|required/i);",
              "});",
              ""
