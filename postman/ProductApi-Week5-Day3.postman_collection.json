  "item": [
    {
      "name": "Create Product Valid",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test(\"Response is JSON\", function () {",
              "    pm.expect(pm.response.headers.get(\"Content-Type\"))",
              "        .to.include(\"application/json\");",
              "});",
              "",
              "pm.test(\"Location header points to created product\", function () {",
              "    const response = pm.response.json();",
              "    const location = pm.response.headers.get(\"Location\");",
              "",
              "    pm.expect(response.id).to.be.a(\"number\").and.to.be.above(0);",
              "    pm.expect(location).to.be.a(\"string\");",
              "    pm.expect(location.toLowerCase())",
              "        .to.include(`/api/products/${response.id}`);",
              "});",
              "",
              "pm.test(\"Created product matches response DTO contract\", function () {",
              "    const response = pm.response.json();",
              "",
              "    pm.expect(response).to.have.property(\"id\");",
              "    pm.expect(response.name).to.eql(\"Mechanical Keyboard\");",
              "    pm.expect(response.price).to.eql(95.5);",
              "    pm.expect(response.quantity).to.eql(0);",
              "});",
              ""
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Mechanical Keyboard\",\n  \"price\": 95.5,\n  \"quantity\": 0\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/products",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "products"
          ]
        }
      },
      "response": []
    },
