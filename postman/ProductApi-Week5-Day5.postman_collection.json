{
  "info": {
    "_postman_id": "35069f24-e89a-4f95-a7d2-5105f25f9fa1",
    "name": "ProductApi - Week 5 Day 5 CRUD Demo",
    "description": "Collection CRUD hoàn chỉnh dùng cho review và demo Day 5. Dữ liệu test được sinh động, ID được lấy từ response và Product thử được xóa ở cuối lượt chạy.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 - Get Product List",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const suffix = `${Date.now()}-${pm.variables.replaceIn(\"{{$randomInt}}\")}`;",
              "pm.collectionVariables.set(\"productName\", `Day5 Demo Product ${suffix}`);",
              "pm.collectionVariables.set(\"updatedProductName\", `Day5 Updated Product ${suffix}`);",
              "pm.collectionVariables.unset(\"createdProductId\");"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response contains items and pagination\", function () {",
              "    const response = pm.response.json();",
              "    pm.expect(response.items).to.be.an(\"array\");",
              "    pm.expect(response.pagination.page).to.eql(1);",
              "    pm.expect(response.pagination.totalItems).to.be.at.least(3);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/products?page=1",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "products"
          ],
          "query": [
            {
              "key": "page",
              "value": "1"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "02 - Search Products",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Search is case-insensitive\", function () {",
              "    const response = pm.response.json();",
              "    pm.expect(response.items).to.be.an(\"array\").that.is.not.empty;",
              "    response.items.forEach(function (product) {",
              "        pm.expect(product.name.toLowerCase()).to.include(\"smart\");",
              "    });",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/products?search=SMART&page=1",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "products"
          ],
          "query": [
            {
              "key": "search",
              "value": "SMART"
            },
            {
              "key": "page",
              "value": "1"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "03 - Get Product Detail",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response follows ProductResponseDto contract\", function () {",
              "    const response = pm.response.json();",
              "    pm.expect(response.id).to.eql(2);",
              "    pm.expect(response.name).to.be.a(\"string\");",
              "    pm.expect(response.categoryId).to.be.above(0);",
              "    pm.expect(response.price).to.be.above(0);",
              "    pm.expect(response.quantity).to.be.at.least(0);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/products/2",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "products",
            "2"
          ]
        }
      },
      "response": []
    },
    {
      "name": "04 - Create Product",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test(\"Created product and Location header are correct\", function () {",
              "    const response = pm.response.json();",
              "    const location = pm.response.headers.get(\"Location\");",
              "    pm.expect(response.id).to.be.a(\"number\").and.to.be.above(0);",
              "    pm.expect(response.name).to.eql(pm.collectionVariables.get(\"productName\"));",
              "    pm.expect(response.categoryId).to.eql(Number(pm.collectionVariables.get(\"categoryId\")));",
              "    pm.expect(response.price).to.eql(250.5);",
              "    pm.expect(response.quantity).to.eql(5);",
              "    pm.expect(location.toLowerCase()).to.include(`/api/products/${response.id}`);",
              "    pm.collectionVariables.set(\"createdProductId\", String(response.id));",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{productName}}\",\n  \"categoryId\": {{categoryId}},\n  \"price\": 250.5,\n  \"quantity\": 5\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/products",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "products"
          ]
        }
      },
      "response": []
    },
    {
      "name": "05 - Read Created Product",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Created product is persisted in PostgreSQL\", function () {",
              "    const response = pm.response.json();",
              "    pm.expect(response.id).to.eql(Number(pm.collectionVariables.get(\"createdProductId\")));",
              "    pm.expect(response.name).to.eql(pm.collectionVariables.get(\"productName\"));",
              "    pm.expect(response.categoryId).to.eql(Number(pm.collectionVariables.get(\"categoryId\")));",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/products/{{createdProductId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "products",
            "{{createdProductId}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "06 - Update Product",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Updated product matches request body\", function () {",
              "    const response = pm.response.json();",
              "    pm.expect(response.id).to.eql(Number(pm.collectionVariables.get(\"createdProductId\")));",
              "    pm.expect(response.name).to.eql(pm.collectionVariables.get(\"updatedProductName\"));",
              "    pm.expect(response.categoryId).to.eql(Number(pm.collectionVariables.get(\"categoryId\")));",
              "    pm.expect(response.price).to.eql(299.99);",
              "    pm.expect(response.quantity).to.eql(8);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{updatedProductName}}\",\n  \"categoryId\": {{categoryId}},\n  \"price\": 299.99,\n  \"quantity\": 8\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/products/{{createdProductId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "products",
            "{{createdProductId}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "07 - Reject Duplicate Product Name",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.collectionVariables.set(",
              "    \"duplicateProductName\",",
              "    pm.collectionVariables.get(\"updatedProductName\").toLowerCase());"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 409\", function () {",
              "    pm.response.to.have.status(409);",
              "});",
              "",
              "pm.test(\"Duplicate rule is case-insensitive in the same category\", function () {",
              "    const response = pm.response.json();",
              "    pm.expect(response.message).to.match(/same name|already exists/i);",
              "    pm.expect(response.message).to.include(pm.collectionVariables.get(\"categoryId\"));",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{duplicateProductName}}\",\n  \"categoryId\": {{categoryId}},\n  \"price\": 100,\n  \"quantity\": 1\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/products",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "products"
          ]
        }
      },
      "response": []
    },
    {
      "name": "08 - Reject Invalid Product",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 400\", function () {",
              "    pm.response.to.have.status(400);",
              "});",
              "",
              "pm.test(\"Validation response uses Problem Details\", function () {",
              "    const response = pm.response.json();",
              "    const body = JSON.stringify(response);",
              "    pm.expect(pm.response.headers.get(\"Content-Type\"))",
              "        .to.include(\"application/problem+json\");",
              "    pm.expect(response).to.have.property(\"errors\");",
              "    pm.expect(body).to.match(/price|greater than 0/i);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Invalid Day5 Product\",\n  \"categoryId\": {{categoryId}},\n  \"price\": 0,\n  \"quantity\": 1\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/products",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "products"
          ]
        }
      },
      "response": []
    },
    {
      "name": "09 - Delete Product",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 204\", function () {",
              "    pm.response.to.have.status(204);",
              "});",
              "",
              "pm.test(\"No Content response has an empty body\", function () {",
              "    pm.expect(pm.response.text()).to.eql(\"\");",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/products/{{createdProductId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "products",
            "{{createdProductId}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "10 - Verify Product Was Deleted",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 404\", function () {",
              "    pm.response.to.have.status(404);",
              "});",
              "",
              "pm.test(\"Deleted product is no longer available\", function () {",
              "    const response = pm.response.json();",
              "    pm.expect(response.message).to.include(pm.collectionVariables.get(\"createdProductId\"));",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/products/{{createdProductId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "products",
            "{{createdProductId}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "11 - Delete Product Not Found",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 404\", function () {",
              "    pm.response.to.have.status(404);",
              "});",
              "",
              "pm.test(\"Not found message includes product id\", function () {",
              "    const response = pm.response.json();",
              "    pm.expect(response.message).to.include(pm.collectionVariables.get(\"missingProductId\"));",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/products/{{missingProductId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "products",
            "{{missingProductId}}"
          ]
        }
      },
      "response": []
    }
