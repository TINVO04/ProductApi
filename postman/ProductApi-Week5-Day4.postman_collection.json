    {
      "name": "03 - Product List Page 1",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"List contains items and pagination metadata\", function () {",
              "    const response = pm.response.json();",
              "",
              "    pm.expect(response.items).to.be.an(\"array\");",
              "    pm.expect(response.pagination).to.be.an(\"object\");",
              "    pm.expect(response.pagination.page).to.eql(1);",
              "    pm.expect(response.pagination.totalItems).to.be.at.least(3);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/products?page=1",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "products"
          ],
          "query": [
            {
              "key": "page",
              "value": "1"
            }
          ]
        }
      },
      "response": []
