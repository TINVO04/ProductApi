  "item": [
    {
      "name": "01 - Health and Initialize Run",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const suffix = `${Date.now()}-${pm.variables.replaceIn(\"{{$randomInt}}\")}`;",
              "const productName = `Day4 Runner Product ${suffix}`;",
              "",
              "pm.collectionVariables.set(\"runToken\", suffix);",
              "pm.collectionVariables.set(\"testProductName\", productName);",
              "pm.collectionVariables.set(\"duplicateProductName\", productName.toLowerCase());",
              "pm.collectionVariables.set(\"updatedProductName\", `Day4 Updated Product ${suffix}`);",
              "pm.collectionVariables.unset(\"createdProductId\");",
              "pm.collectionVariables.unset(\"sameNameProductId\");"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Health response is JSON\", function () {",
              "    pm.expect(pm.response.headers.get(\"Content-Type\"))",
              "        .to.include(\"application/json\");",
              "    pm.expect(pm.response.json()).to.be.an(\"object\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "health"
          ]
        }
      },
      "response": []
    },
