          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Updated product matches request\", function () {",
              "    const response = pm.response.json();",
              "",
              "    pm.expect(response.id).to.eql(Number(pm.collectionVariables.get(\"createdProductId\")));",
              "    pm.expect(response.name).to.eql(pm.collectionVariables.get(\"updatedProductName\"));",
              "    pm.expect(response.categoryId).to.eql(Number(pm.collectionVariables.get(\"categoryId\")));",
              "    pm.expect(response.price).to.eql(129.99);",
              "    pm.expect(response.quantity).to.eql(7);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
