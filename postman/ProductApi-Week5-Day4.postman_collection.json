      "name": "08 - Create Product Valid",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test(\"Created product and Location header are correct\", function () {",
              "    const response = pm.response.json();",
              "    const location = pm.response.headers.get(\"Location\");",
              "",
              "    pm.expect(response.id).to.be.a(\"number\").and.to.be.above(0);",
              "    pm.expect(response.name).to.eql(pm.collectionVariables.get(\"testProductName\"));",
              "    pm.expect(response.categoryId).to.eql(Number(pm.collectionVariables.get(\"categoryId\")));",
              "    pm.expect(response.price).to.eql(95.5);",
              "    pm.expect(response.quantity).to.eql(0);",
              "    pm.expect(location.toLowerCase()).to.include(`/api/products/${response.id}`);",
              "",
              "    pm.collectionVariables.set(\"createdProductId\", String(response.id));",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
